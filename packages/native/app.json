{
  "expo": {
    "name": "Sanskrit Student",
    "slug": "sanskrit-student",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sanskritstudent.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.sanskritstudent.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-updates",
      "react-native-image-crop-picker"
    ],
    "updates": {
      "url": "https://u.expo.dev/87608b30-7950-40cd-9732-8af2add0ed96"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "scheme": "sanskrit-student",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "87608b30-7950-40cd-9732-8af2add0ed96"
      }
    },
    "owner": "dvancouvering"
  }
}
